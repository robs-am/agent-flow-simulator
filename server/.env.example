# Copie este arquivo para `.env` e preencha os valores.
# O `.env` é ignorado pelo git (não sobe a chave por engano).

# Chave da API do Claude — necessária pro modo "Analisar" (classificação
# por IA do texto livre). Sem ela, os exemplos prontos continuam funcionando,
# mas o botão Analisar devolve 503.
# Pegue a sua em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Opcional: sobe o limite de requisições da análise de repositório GitHub
# (sem token: 60/hora por IP; com token: 5.000/hora).
GITHUB_TOKEN=
